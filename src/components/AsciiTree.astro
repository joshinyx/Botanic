---
// Decorative ASCII tree — background only, no overlay content
---

<pre id="ascii-tree" aria-hidden="true"></pre>

<style>
  #ascii-tree {
    position: fixed;
    inset: 0;
    margin: 0;
    padding: 0;
    white-space: pre;
    font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    font-size: 13px;
    line-height: 1.0;
    letter-spacing: 0;
    user-select: none;
    pointer-events: none;
    z-index: 0;
    opacity: 0.28;
  }

  @media (max-width: 640px) {
    #ascii-tree { opacity: 0.15; font-size: 11px; }
  }
</style>

<script is:inline>
(function () {
  const treeEl = document.getElementById('ascii-tree');
  if (!treeEl) return;

  function measureCell() {
    const probe = document.createElement('span');
    probe.textContent = 'M';
    probe.style.cssText = 'position:absolute;visibility:hidden;font-family:ui-monospace,"SF Mono",Menlo,Consolas,monospace;font-size:13px;line-height:1.0;letter-spacing:0;white-space:pre;';
    document.body.appendChild(probe);
    const r = probe.getBoundingClientRect();
    document.body.removeChild(probe);
    return { w: r.width, h: r.height };
  }

  let CELL, COLS, ROWS, ASPECT;
  let density, override, tier;

  function setupGrid() {
    CELL  = measureCell();
    COLS  = Math.ceil(window.innerWidth  / CELL.w);
    ROWS  = Math.ceil(window.innerHeight / CELL.h);
    density  = Array.from({ length: ROWS }, () => new Float32Array(COLS));
    override = Array.from({ length: ROWS }, () => new Array(COLS).fill(null));
    tier     = Array.from({ length: ROWS }, () => new Uint8Array(COLS));
  }

  function inBounds(x, y) { return x >= 0 && y >= 0 && x < COLS && y < ROWS; }
  function clamp(v, a, b)  { return v < a ? a : v > b ? b : v; }
  function rand(a, b)      { return a + Math.random() * (b - a); }
  function pick(arr)        { return arr[(Math.random() * arr.length) | 0]; }

  // Tier colors — adapted for dark backgrounds
  const TIERS = ['#4f9276', '#52b788', '#74c69d', '#3a7d5e', '#2d6a4f'];

  let branches = [], blobs = [];

  function buildTree() {
    branches = []; blobs = [];
    const baseX   = COLS * 0.5;
    const baseY   = ROWS - 2;
    const trunkH  = Math.min(ROWS * 0.28, 18);
    const trunkTopX = baseX + rand(-0.8, 0.8);
    const trunkTopY = baseY - trunkH;

    branches.push({ x1: baseX, y1: baseY, x2: trunkTopX, y2: trunkTopY, w1: 4.2, w2: 2.2, tier: 4, bark: true });

    function grow(x, y, angle, length, thickness, depthLevel) {
      if (depthLevel > 5 || length < 2.2) {
        blobs.push({ cx: x + Math.cos(angle) * length * 0.2, cy: y + Math.sin(angle) * length * 0.2, rx: rand(2.6, 4.6) * rand(0.9, 1.3), ry: rand(2.6, 4.6) * rand(0.7, 1.0), density: rand(0.9, 1.4), tier: 2 + (Math.random() < 0.55 ? 1 : 0) });
        return;
      }
      const ex = x + Math.cos(angle) * length;
      const ey = y + Math.sin(angle) * length;
      branches.push({ x1: x, y1: y, x2: ex, y2: ey, w1: thickness, w2: thickness * 0.72, tier: depthLevel <= 1 ? 4 : 3, bark: depthLevel <= 1 });
      if (depthLevel >= 1 && Math.random() < 0.45) {
        blobs.push({ cx: (x + ex) / 2 + rand(-2, 2), cy: (y + ey) / 2 + rand(-1.5, 1.5), rx: rand(2.2, 3.6), ry: rand(1.6, 2.4), density: rand(0.6, 1.0), tier: 2 });
      }
      const childCount = depthLevel < 2 ? (Math.random() < 0.35 ? 3 : 2) : (Math.random() < 0.7 ? 2 : 1);
      const spread = rand(0.5, 0.9);
      for (let i = 0; i < childCount; i++) {
        let off = childCount === 1 ? rand(-0.4, 0.4) : childCount === 2 ? (i === 0 ? -1 : 1) * spread * rand(0.7, 1.1) : (i - 1) * spread * rand(0.7, 1.1);
        const childAngle = angle + off + rand(-0.25, 0.25) + (Math.random() < 0.7 ? -0.12 : 0);
        grow(ex, ey, childAngle, length * rand(0.62, 0.82), Math.max(0.55, thickness * rand(0.62, 0.78)), depthLevel + 1);
      }
    }

    const firstLen = trunkH * 0.9;
    grow(trunkTopX, trunkTopY, -Math.PI / 2, firstLen, 1.6, 1);
    grow(trunkTopX, trunkTopY + 1, -Math.PI / 2 - 0.55, firstLen * 0.95, 1.4, 1);
    grow(trunkTopX, trunkTopY + 1, -Math.PI / 2 + 0.55, firstLen * 0.95, 1.4, 1);

    const canopyCX = trunkTopX;
    const canopyCY = trunkTopY - trunkH * 0.55;
    const canopyRX = Math.min(COLS * 0.42, trunkH * 1.9);
    const canopyRY = Math.min(ROWS * 0.32, trunkH * 1.2);

    blobs.push({ cx: canopyCX, cy: canopyCY, rx: canopyRX, ry: canopyRY, density: 0.55, tier: 1, soft: true });
    blobs.push({ cx: canopyCX, cy: canopyCY, rx: canopyRX * 0.78, ry: canopyRY * 0.82, density: 0.55, tier: 2 });

    for (let i = 0; i < 22; i++) {
      const a = Math.random() * Math.PI * 2;
      const r = Math.sqrt(Math.random()) * 0.92;
      blobs.push({ cx: canopyCX + Math.cos(a) * r * canopyRX / ASPECT, cy: canopyCY + Math.sin(a) * r * canopyRY, rx: rand(2.4, 4.2), ry: rand(1.6, 2.6), density: rand(0.7, 1.1), tier: 2 + (Math.random() < 0.4 ? 1 : 0) });
    }
    for (let i = 0; i < 6; i++) {
      const a = -Math.PI / 2 + rand(-0.9, 0.9);
      const r = rand(0.5, 0.95);
      blobs.push({ cx: canopyCX + Math.cos(a) * r * canopyRX / ASPECT, cy: canopyCY + Math.sin(a) * r * canopyRY, rx: rand(1.8, 3.2), ry: rand(1.2, 2.0), density: rand(0.5, 0.85), tier: 1 });
    }

    for (let i = 0; i < COLS; i += 2) {
      if (Math.random() < 0.6) {
        const gx = i + (Math.random() < 0.5 ? 0 : 1);
        const gy = Math.floor(baseY) + (Math.random() < 0.3 ? 1 : 0);
        if (inBounds(gx, gy)) { density[gy][gx] = Math.max(density[gy][gx], 0.7); tier[gy][gx] = Math.max(tier[gy][gx], 1); }
      }
    }
    for (let x = 0; x < COLS; x++) {
      const y = Math.floor(baseY);
      if (inBounds(x, y)) {
        density[y][x] = Math.max(density[y][x], 0.4);
        if (!override[y][x]) { override[y][x] = Math.random() < 0.35 ? pick(['_', '.']) : '_'; tier[y][x] = Math.max(tier[y][x], 1); }
      }
    }
  }

  function rasterBranch(b) {
    const dx = b.x2 - b.x1, dy = b.y2 - b.y1;
    const steps = Math.max(3, Math.ceil(Math.hypot(dx, dy / ASPECT) * 1.6));
    for (let i = 0; i <= steps; i++) {
      const t = i / steps;
      const x = b.x1 + dx * t, y = b.y1 + dy * t;
      const w = b.w1 * (1 - t) + b.w2 * t;
      const dirLen = Math.hypot(dx, dy) || 1;
      const nx = -dy / dirLen, ny = dx / dirLen;
      const halfW = Math.max(1, Math.ceil(w) + 1);
      for (let k = -halfW; k <= halfW; k++) {
        const ix = Math.floor(x + nx * k * 0.9), iy = Math.floor(y + ny * k * 0.9);
        if (!inBounds(ix, iy)) continue;
        const dens = Math.max(0, 1 - (Math.abs(k) - w) * 0.55);
        if (dens <= 0) continue;
        density[iy][ix] = Math.min(2.5, density[iy][ix] + dens * 1.1);
        if (b.tier > tier[iy][ix]) tier[iy][ix] = b.tier;
        if (b.bark && Math.abs(k) <= w * 0.8 && !override[iy][ix]) {
          const absRatio = Math.abs(dx) / (Math.abs(dy) + 0.0001);
          override[iy][ix] = absRatio < 0.4 ? pick(['║', '║', '│', '┃', '|']) : dx * dy > 0 ? pick(['\\', '╲']) : pick(['/', '╱']);
        }
      }
    }
  }

  function rasterBlob(b) {
    const xr = Math.ceil(b.rx / ASPECT) + 1, yr = Math.ceil(b.ry) + 1;
    for (let dy = -yr; dy <= yr; dy++) {
      for (let dx = -xr; dx <= xr; dx++) {
        const gx = Math.floor(b.cx + dx), gy = Math.floor(b.cy + dy);
        if (!inBounds(gx, gy)) continue;
        const n = ((dx * ASPECT) / b.rx) ** 2 + (dy / b.ry) ** 2;
        if (n > 1.1) continue;
        const d = Math.max(0, 1 - n) * b.density * (0.85 + Math.random() * 0.3);
        if (d <= 0) continue;
        density[gy][gx] = Math.min(2.5, density[gy][gx] + d);
        if (b.tier > tier[gy][gx]) tier[gy][gx] = b.tier;
      }
    }
  }

  let jitter, frozenChar;

  function resetJitter() {
    jitter = Array.from({ length: ROWS }, () => Float32Array.from({ length: COLS }, () => Math.random()));
  }

  function densityToChar(d, y, x) {
    const ov = override[y][x];
    if (ov && d > 0.45) return ov;
    if (d <= 0.02) return ' ';
    if (d < 0.12)  return '.';
    if (d < 0.22)  return '·';
    if (d < 0.34)  return ',';
    if (d < 0.5)   return ':';
    if (d < 0.7)   return jitter[y][x] < 0.35 ? 'o' : '*';
    if (d < 0.95)  { const r = jitter[y][x]; return r < 0.33 ? 'o' : r < 0.66 ? '❦' : '✿'; }
    if (d < 1.25)  { const r = jitter[y][x]; return r < 0.33 ? '❀' : r < 0.66 ? '&' : '@'; }
    return '@';
  }

  function freezeChars() {
    frozenChar = Array.from({ length: ROWS }, () => new Array(COLS).fill(' '));
    for (let y = 0; y < ROWS; y++)
      for (let x = 0; x < COLS; x++)
        frozenChar[y][x] = densityToChar(density[y][x], y, x);
  }

  function wrap(s, t) {
    if (/^\s+$/.test(s)) return s;
    return `<span style="color:${TIERS[t] || TIERS[3]}">${s}</span>`;
  }

  let bornAt;
  const GROW_MS = 2600;

  function render(now) {
    const elapsed = now - bornAt;
    const finished = elapsed > GROW_MS + 350;
    const baseY = ROWS - 2;
    let html = '';
    for (let y = 0; y < ROWS; y++) {
      let curTier = -1, buf = '';
      for (let x = 0; x < COLS; x++) {
        const d = density[y][x];
        const norm = clamp((baseY - y) / Math.max(1, baseY), 0, 1);
        const reveal = norm * 0.82 + jitter[y][x] * 0.18;
        const visible = elapsed >= reveal * GROW_MS;
        let ch = ' ', t = -1;
        if (visible && d >= 0.02) { ch = frozenChar[y][x]; t = tier[y][x] || 2; }
        if (t !== curTier) { if (buf.length) html += wrap(buf, curTier); buf = ''; curTier = t; }
        ch = ch === '<' ? '&lt;' : ch === '>' ? '&gt;' : ch === '&' ? '&amp;' : ch;
        buf += ch;
      }
      if (buf.length) html += wrap(buf, curTier);
      html += '\n';
    }
    treeEl.innerHTML = html;
    if (!finished) requestAnimationFrame(render);
  }

  function resetScene() {
    setupGrid();
    ASPECT = CELL.w / CELL.h;
    resetJitter();
    for (let y = 0; y < ROWS; y++) { override[y].fill(null); tier[y].fill(0); density[y].fill(0); }
    buildTree();
    for (const b of branches) rasterBranch(b);
    for (const b of blobs)    rasterBlob(b);
    freezeChars();
    bornAt = performance.now();
    requestAnimationFrame(render);
  }

  let resizeTimer;
  window.addEventListener('resize', () => { clearTimeout(resizeTimer); resizeTimer = setTimeout(resetScene, 150); });
  resetScene();
})();
</script>
