---
import Base from "@/layouts/Base.astro";
import Header from "@/components/layout/Header.astro";
import SearchFilters from "@/components/islands/SearchFilters";
import PlantGrid from "@/components/islands/PlantGrid";
import { createSupabaseServerClient } from "@/lib/supabase";
import { getLang, t } from "@/lib/i18n";
import AsciiTree from "@/components/AsciiTree.astro";
import HeroHeading from "@/components/islands/HeroHeading.astro";
import type { Plant, UserProfile, PlantTagRow, PlantFamilyRow } from "@/types";

const lang = getLang(Astro.cookies);
const url = Astro.url;
const filterName     = url.searchParams.get("name") ?? "";
const filterTags     = url.searchParams.get("tags")?.split(",").filter(Boolean)     ?? [];
const filterFamily   = url.searchParams.get("family")?.split(",").filter(Boolean)   ?? [];
const filterCountry  = url.searchParams.get("country")?.split(",").filter(Boolean)  ?? [];
const filterClimate  = url.searchParams.get("climate")?.split(",").filter(Boolean)  ?? [];
const filterDuration = url.searchParams.get("duration")?.split(",").filter(Boolean) ?? [];
const filterAuthor   = url.searchParams.get("author") ?? "";

const supabase = createSupabaseServerClient(Astro.cookies, Astro.request);

let query = supabase
  .from("plants")
  .select("*, users(username, name, bio, avatar_url, followers_count, following_count)")
  .eq("status", "approved")
  .order("created_at", { ascending: false });

if (filterName)            query = query.ilike("name", `%${filterName}%`);
if (filterCountry.length)  query = query.in("origin_country", filterCountry);
if (filterClimate.length)  query = query.in("climate", filterClimate);
if (filterDuration.length) query = query.in("duration", filterDuration);
if (filterTags.length)     query = query.contains("tags", filterTags);
if (filterFamily.length)   query = query.in("family", filterFamily);
if (filterAuthor) {
  const { data: authorUser } = await supabase
    .from("users").select("id").eq("username", filterAuthor).maybeSingle();
  query = query.eq("user_id", authorUser?.id ?? "00000000-0000-0000-0000-000000000000");
}

const { data: plants } = await query.limit(120);

type PlantWithUser = Plant & { users: Pick<UserProfile, "username" | "name" | "bio" | "avatar_url" | "followers_count" | "following_count"> | null };
const plantList: PlantWithUser[] = (plants ?? []) as PlantWithUser[];

const [{ data: countryRows }, { data: tagRows }, { data: familyRows }] = await Promise.all([
  supabase.from("plants").select("origin_country").eq("status", "approved"),
  supabase.from("plant_tags").select("key, label_es, label_en").eq("active", true).order("sort_order"),
  supabase.from("plant_families").select("key, label_es, label_en").eq("active", true).order("sort_order"),
]);

const countries     = [...new Set((countryRows ?? []).map((r) => r.origin_country as string))].sort();
const activeTags    = (tagRows    ?? []) as Pick<PlantTagRow,    "key" | "label_es" | "label_en">[];
const activeFamilies = (familyRows ?? []) as Pick<PlantFamilyRow, "key" | "label_es" | "label_en">[];

const hasFilters = filterName || filterTags.length || filterFamily.length || filterCountry.length || filterClimate.length || filterDuration.length || filterAuthor;

const countLabel = plantList.length === 1
  ? `1 ${t("home.count.one", lang)}`
  : `${plantList.length} ${t("home.count.other", lang)}`;
---

<Base title={t("home.title", lang)}>
  <Header />

  <AsciiTree />

  <!-- Radial glow behind hero — full width, fuera del max-w container -->
  <div aria-hidden="true" style="
    position:fixed; inset:0; pointer-events:none; z-index:0;
    background: radial-gradient(ellipse 70% 40% at 50% 0%, rgba(58,125,94,0.09) 0%, transparent 70%);
  "></div>

  <main class="max-w-[1200px] mx-auto px-6" style="position:relative; z-index:1">

    <!-- Hero -->
    <div class="text-center pt-32 pb-24 md:pt-40 md:pb-28">
      <div class="mb-8">
        <HeroHeading
          line1={lang === "es" ? "Bienvenido a" : "Welcome to"}
          line2="Botanic"
        />
      </div>
      <p class="max-w-lg mx-auto mb-9"
         style="font-size:1rem; line-height:1.75; color:var(--color-text-muted);
                font-weight:400; letter-spacing:-0.01em">
        {t("home.welcome.desc", lang)}
      </p>
      <div class="flex items-center justify-center gap-3 flex-wrap">
        <a href="/plants/submit"
           class="inline-flex items-center px-5 py-2.5 text-sm text-white transition-opacity hover:opacity-90"
           style="background:var(--color-brand); font-weight:510; font-feature-settings:'cv01','ss03';
                  border-radius:9999px">
          {t("home.welcome.cta.primary", lang)}
        </a>
        <a href="#catalog"
           class="inline-flex items-center px-5 py-2.5 text-sm transition-colors"
           style="background:rgba(255,255,255,0.04); border:1px solid var(--color-border-std);
                  color:var(--color-text-secondary); font-weight:510; font-feature-settings:'cv01','ss03';
                  border-radius:9999px">
          {t("home.welcome.cta.secondary", lang)}
        </a>
      </div>
    </div>

    <!-- Catalog anchor -->
    <div id="catalog"></div>

    <div class="mb-8">
      <SearchFilters
        client:load
        lang={lang}
        initialName={filterName}
        initialTags={filterTags}
        initialFamily={filterFamily}
        initialCountry={filterCountry}
        initialClimate={filterClimate}
        initialDuration={filterDuration}
        initialAuthor={filterAuthor}
        countries={countries}
        activeFamilies={activeFamilies}
        activeTags={activeTags}
      />
    </div>

    <PlantGrid
      client:load
      initialPlants={plantList}
      initialHasFilters={!!hasFilters}
      lang={lang}
      emptyTitle={t("home.empty.title", lang)}
      emptyFilters={t("home.empty.filters", lang)}
      emptyFirst={t("home.empty.first", lang)}
      clearLabel={t("home.clear", lang)}
      submittedByLabel={t("plant.submittedBy", lang)}
      countOne={t("home.count.one", lang)}
      countOther={t("home.count.other", lang)}
      filteredLabel={t("home.filtered", lang)}
    />
  </main>
</Base>
