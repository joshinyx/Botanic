---
import Base from "@/layouts/Base.astro";
import Header from "@/components/layout/Header.astro";
import PlantSubmitForm from "@/components/islands/PlantSubmitForm";
import { getSession } from "@/lib/auth";
import { getLang, t } from "@/lib/i18n";
import { createSupabaseServerClient } from "@/lib/supabase";
import type { PlantTagRow, PlantFamilyRow, PlantClimateRow, PlantDurationRow } from "@/types";

const session = await getSession(Astro.cookies, Astro.request);
if (!session) return Astro.redirect("/auth/login");

const lang = getLang(Astro.cookies);
const supabase = createSupabaseServerClient(Astro.cookies, Astro.request);

const [{ data: tagRows }, { data: familyRows }, { data: climateRows }, { data: durationRows }] = await Promise.all([
  supabase.from("plant_tags").select("key, label_es, label_en").eq("active", true).order("sort_order"),
  supabase.from("plant_families").select("key, label_es, label_en").eq("active", true).order("sort_order"),
  supabase.from("plant_climates").select("key, label_es, label_en").eq("active", true).order("sort_order"),
  supabase.from("plant_durations").select("key, label_es, label_en").eq("active", true).order("sort_order"),
]);

type ActiveItem = Pick<PlantTagRow, "key" | "label_es" | "label_en">;
const activeTags      = (tagRows      ?? []) as ActiveItem[];
const activeFamilies  = (familyRows   ?? []) as ActiveItem[];
const activeClimates  = (climateRows  ?? []) as Pick<PlantClimateRow,  "key" | "label_es" | "label_en">[];
const activeDurations = (durationRows ?? []) as Pick<PlantDurationRow, "key" | "label_es" | "label_en">[];
---

<Base title={t("submit.title", lang)}>
  <Header />
  <main class="max-w-[1200px] mx-auto px-6 py-10">
    <a href="/" class="inline-flex items-center gap-1.5 text-xs mb-6 transition-colors"
       style="font-weight:510; color:var(--color-text-subtle)">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M19 12H5M12 19l-7-7 7-7"/>
      </svg>
      {t("submit.back", lang)}
    </a>

    <h1 class="text-[32px] tracking-[-0.704px] mb-2 text-center"
        style="font-weight:510; font-feature-settings:'cv01','ss03'; color:var(--color-text-primary)">
      {t("submit.title", lang)}
    </h1>
    <p class="text-sm mb-8 text-center" style="color:var(--color-text-muted)">
      {t("submit.subtitle", lang)}
    </p>

    <PlantSubmitForm client:load lang={lang} activeTags={activeTags} activeFamilies={activeFamilies} activeClimates={activeClimates} activeDurations={activeDurations} />
  </main>
</Base>
