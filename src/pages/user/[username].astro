---
import Base from "@/layouts/Base.astro";
import Header from "@/components/layout/Header.astro";
import PlantCard from "@/components/ui/PlantCard.astro";
import ProfileActions from "@/components/islands/ProfileActions";
import AvatarEditor from "@/components/islands/AvatarEditor";
import FollowButton from "@/components/islands/FollowButton";
import { createSupabaseServerClient } from "@/lib/supabase";
import { getSession } from "@/lib/auth";
import { getLang, t } from "@/lib/i18n";
import { isValidHttpUrl } from "@/lib/validate";
import type { Plant, UserProfile } from "@/types";

const { username } = Astro.params;
if (!username) return Astro.redirect("/");

const lang = getLang(Astro.cookies);
const supabase = createSupabaseServerClient(Astro.cookies, Astro.request);

const { data: profile } = await supabase
  .from("users")
  .select("id, name, username, bio, social_links, avatar_url, followers_count, following_count, created_at")
  .eq("username", username.toLowerCase())
  .maybeSingle();

if (!profile) return Astro.redirect("/");
type PublicProfile = Pick<UserProfile, "id" | "name" | "username" | "bio" | "social_links" | "avatar_url" | "followers_count" | "following_count" | "created_at">;
const user = profile as PublicProfile;

const { data: plants } = await supabase
  .from("plants").select("*, users(username, name)")
  .eq("user_id", user.id).eq("status", "approved")
  .order("created_at", { ascending: false });

type PlantWithUser = Plant & { users: Pick<UserProfile, "username" | "name"> | null };
const plantList = (plants ?? []) as PlantWithUser[];

const session = await getSession(Astro.cookies, Astro.request);
const isOwner = session?.id === user.id;

// Follow status for the current viewer (non-owner only)
let initialIsFollowing = false;
let initialNotificationsEnabled = true;
if (session && !isOwner) {
  const { data: followRow } = await supabase
    .from("follows")
    .select("notifications_enabled")
    .eq("follower_id", session.id)
    .eq("following_id", user.id)
    .maybeSingle();
  initialIsFollowing = !!followRow;
  initialNotificationsEnabled = followRow?.notifications_enabled ?? true;
}

const socials = (user.social_links ?? {}) as Record<string, string>;
type SocialIcon = { path: string; type: "stroke" | "fill" };
const socialIcons: Record<string, SocialIcon> = {
  website:   { type: "stroke", path: "M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2zm0 0v20M2 12h20M4.93 4.93C6.36 8.36 8 10 12 10s5.64-1.64 7.07-5.07M4.93 19.07C6.36 15.64 8 14 12 14s5.64 1.36 7.07 4.93" },
  twitter:   { type: "fill", path: "M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.747l7.74-8.855L2.25 2.25h6.826l4.26 5.637 4.908-5.637zm-1.161 17.52h1.833L7.084 4.126H5.117z" },
  instagram: { type: "fill", path: "M12 0C8.74 0 8.333.015 7.053.072 5.775.132 4.905.333 4.14.63c-.789.306-1.459.717-2.126 1.384S.935 3.35.63 4.14C.333 4.905.131 5.775.072 7.053.012 8.333 0 8.74 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.74 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 2.16c3.203 0 3.585.016 4.85.071 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z" },
  github:    { type: "fill", path: "M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12" },
  linkedin:  { type: "fill", path: "M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" },
};
const activeSocials = Object.entries(socials)
  .filter(([, v]) => v && isValidHttpUrl(v))
  .map(([key, url]) => ({ key, url, icon: socialIcons[key] ?? socialIcons["website"] }));
const initial = user.name.charAt(0).toUpperCase();
const joinDate = new Date(user.created_at).toLocaleDateString(
  lang === "es" ? "es-ES" : "en-US",
  { month: "long", year: "numeric" }
);
---

<Base title={`@${user.username}`}>
  <Header />
  <main class="max-w-[1200px] mx-auto px-6 py-10">

    <!-- Profile header -->
    <div class="rounded-panel p-6 mb-8 flex flex-col sm:flex-row sm:items-start gap-5"
         style="background:var(--color-bg-card); border:1px solid var(--color-border-std)">
      <AvatarEditor
        client:load
        name={user.name}
        initialAvatarUrl={user.avatar_url ?? null}
        isOwner={isOwner}
      />

      <div class="flex-1 min-w-0">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div>
            <h1 class="text-[20px] tracking-[-0.24px]"
                style="font-weight:590; font-feature-settings:'cv01','ss03'; color:var(--color-text-primary)">
              {user.name}
            </h1>
            <p class="text-sm mt-0.5" style="font-weight:510; color:var(--color-text-subtle)">
              @{user.username}
            </p>
          </div>

          <!-- Actions: edit (owner) or follow (visitor) -->
          <div class="flex items-center gap-2">
            {isOwner && (
              <ProfileActions client:load lang={lang}
                initialName={user.name}
                initialBio={user.bio ?? ""}
                initialSocials={socials}
              />
            )}
            {!isOwner && session && (
              <FollowButton
                client:load
                targetUserId={user.id}
                isOwner={false}
                initialIsFollowing={initialIsFollowing}
                initialNotificationsEnabled={initialNotificationsEnabled}
              />
            )}
          </div>
        </div>

        {user.bio && (
          <p class="text-sm mt-3 leading-relaxed max-w-xl" style="color:var(--color-text-muted)">
            {user.bio}
          </p>
        )}

        {activeSocials.length > 0 && (
          <div class="flex items-center gap-3 mt-4">
            {activeSocials.map(({ key, url, icon }) => (
              <a href={url} target="_blank" rel="noopener noreferrer"
                 class="transition-colors" style="color:var(--color-text-subtle)" title={key}>
                <svg width="15" height="15" viewBox="0 0 24 24"
                     fill={icon.type === "fill" ? "currentColor" : "none"}
                     stroke={icon.type === "stroke" ? "currentColor" : "none"}
                     stroke-width="1.5">
                  <path d={icon.path} />
                </svg>
              </a>
            ))}
          </div>
        )}

        <!-- Stats row -->
        <div class="flex items-center gap-4 mt-4 flex-wrap">
          <div class="flex items-center gap-1.5">
            <span class="text-sm" style="font-weight:510; color:var(--color-text-primary)">{user.followers_count}</span>
            <span class="text-xs" style="color:var(--color-text-subtle)">
              {user.followers_count === 1 ? "seguidor" : "seguidores"}
            </span>
          </div>
          <div class="w-px h-3" style="background:var(--color-border-std)"></div>
          <div class="flex items-center gap-1.5">
            <span class="text-sm" style="font-weight:510; color:var(--color-text-primary)">{user.following_count}</span>
            <span class="text-xs" style="color:var(--color-text-subtle)">siguiendo</span>
          </div>
          <div class="w-px h-3" style="background:var(--color-border-std)"></div>
          <div class="flex items-center gap-1.5">
            <span class="text-sm" style="font-weight:510; color:var(--color-text-primary)">{plantList.length}</span>
            <span class="text-xs" style="color:var(--color-text-subtle)">
              {plantList.length === 1 ? t("home.count.one", lang) : t("home.count.other", lang)}
            </span>
          </div>
          <div class="w-px h-3" style="background:var(--color-border-std)"></div>
          <span class="text-xs" style="color:var(--color-text-subtle)">
            {t("profile.joined", lang)} {joinDate}
          </span>
        </div>
      </div>
    </div>

    <!-- Plants -->
    <div>
      <h2 class="text-[15px] mb-5"
          style="font-weight:590; font-feature-settings:'cv01','ss03'; color:var(--color-text-primary)">
        {t("profile.plants", lang)}
      </h2>

      {plantList.length > 0 ? (
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
          {plantList.map((plant) => <PlantCard plant={plant} lang={lang} />)}
        </div>
      ) : (
        <div class="flex flex-col items-center justify-center py-16 rounded-card border text-center"
             style="border-color:var(--color-border-subtle); background:var(--color-bg-card)">
          <svg class="mb-3" style="color:var(--color-text-faint)"
               width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
            <path d="M12 2a7 7 0 0 1 7 7c0 5-7 13-7 13S5 14 5 9a7 7 0 0 1 7-7z"/>
            <circle cx="12" cy="9" r="2.5"/>
          </svg>
          <p class="text-sm" style="font-weight:510; color:var(--color-text-subtle)">
            {t("profile.noPlants", lang)}
          </p>
          {isOwner && (
            <a href="/plants/submit" class="mt-3 px-4 py-2 rounded text-xs text-white transition-colors"
               style="background:var(--color-brand); font-weight:510">
              {t("profile.submitFirst", lang)}
            </a>
          )}
        </div>
      )}
    </div>
  </main>
</Base>
