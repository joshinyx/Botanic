---
import Base from "@/layouts/Base.astro";
import AuthBrand from "@/components/islands/AuthBrand";
import ThemeToggle from "@/components/islands/ThemeToggle";
import LanguageSwitcher from "@/components/islands/LanguageSwitcher";
import ForgotPasswordForm from "@/components/islands/ForgotPasswordForm";
import { getLang, t } from "@/lib/i18n";

const lang = getLang(Astro.cookies);
---

<Base title={t("auth.forgot.title", lang)}>
  <div class="min-h-screen flex flex-col items-center justify-center px-4 py-12 relative"
       style="background:var(--color-bg-base)">
    <div class="absolute top-4 right-4 flex items-center gap-2">
      <ThemeToggle client:load />
      <LanguageSwitcher client:load currentLang={lang} />
    </div>

    <AuthBrand client:load />
    <ForgotPasswordForm client:load lang={lang} />
  </div>
</Base>
