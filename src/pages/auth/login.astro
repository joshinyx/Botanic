---
import Base from "@/layouts/Base.astro";
import AuthForm from "@/components/islands/AuthForm";
import AuthBrand from "@/components/islands/AuthBrand";
import ThemeToggle from "@/components/islands/ThemeToggle";
import LanguageSwitcher from "@/components/islands/LanguageSwitcher";
import { getSession } from "@/lib/auth";
import { getLang, t } from "@/lib/i18n";

const session = await getSession(Astro.cookies, Astro.request);
if (session) return Astro.redirect("/");

const lang = getLang(Astro.cookies);
---

<Base title={t("auth.signin.title", lang)}>
  <div class="min-h-screen flex flex-col items-center justify-center px-4 py-12 relative"
       style="background:var(--color-bg-base)">
    <div class="absolute top-4 right-4 flex items-center gap-2">
      <ThemeToggle client:load />
      <LanguageSwitcher client:load currentLang={lang} />
    </div>

    <AuthBrand client:load />

    <AuthForm client:load lang={lang} />

    <p class="mt-6 text-xs" style="color:var(--color-text-subtle)">
      {t("auth.terms", lang)}{" "}
      <a href="/terms" class="transition-colors hover:underline underline-offset-2"
         style="color:var(--color-text-muted)">
        {t("auth.terms.link", lang)}
      </a>
    </p>
  </div>
</Base>
