---
import "../styles/global.css";
import ThemeToggle from "@/components/islands/ThemeToggle";
import LanguageSwitcher from "@/components/islands/LanguageSwitcher";
import UserDropdown from "@/components/islands/UserDropdown";
import { createSupabaseServerClient } from "@/lib/supabase";
import { getSession } from "@/lib/auth";
import { getLang, t } from "@/lib/i18n";

interface Props {
  title: string;
}

const { title } = Astro.props;

const lang = getLang(Astro.cookies);
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: "/dashboard",              label: t("dash.nav.overview",    lang) },
  { href: "/dashboard/submissions",  label: t("dash.nav.submissions", lang) },
  { href: "/dashboard/staff",        label: t("dash.nav.staff",       lang) },
  { href: "/dashboard/logs",         label: t("dash.nav.logs",        lang) },
  { href: "/dashboard/content",      label: t("dash.nav.content",     lang) },
];

const session = await getSession(Astro.cookies, Astro.request);
let username: string | null = null;
let userRole: string | null = null;
let userName: string | null = null;
let userAvatarUrl: string | null = null;

if (session) {
  const supabase = createSupabaseServerClient(Astro.cookies, Astro.request);
  const { data } = await supabase
    .from("users")
    .select("username, role, name, avatar_url")
    .eq("id", session.id)
    .maybeSingle();
  username     = data?.username ?? (session.user_metadata?.username as string | undefined) ?? null;
  userRole     = data?.role ?? null;
  userName     = data?.name ?? null;
  userAvatarUrl = data?.avatar_url ?? null;
}
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Dashboard</title>
    <script is:inline>
      (function(){
        var t=localStorage.getItem("bc_theme");
        document.documentElement.dataset.theme=t==="light"?"light":"dark";
      })();
    </script>
  </head>
  <body class="min-h-screen" style="background:var(--color-bg-base); color:var(--color-text-primary)">

    <!-- Top navbar (same as Header.astro) -->
    <header
      class="sticky top-0 z-50 border-b"
      style="background:var(--color-bg-panel); border-color:var(--color-border-subtle)"
    >
      <div class="max-w-[1200px] mx-auto px-6 h-12 flex items-center gap-3">
        <!-- Brand + Dashboard label -->
        <a href="/" class="shrink-0 transition-opacity hover:opacity-75">
          <img src="/images/botanic.svg" alt="BotanicCatalog"
               width="22" height="23"
               style="display:block; filter:var(--logo-filter)" />
        </a>
        <div class="w-px h-4 shrink-0" style="background:var(--color-border-std)"></div>
        <a href="/dashboard"
           class="text-xs shrink-0 transition-colors hover:opacity-80"
           style="font-weight:510; font-feature-settings:'cv01','ss03'; color:var(--color-text-muted)">
          Dashboard
        </a>

        <!-- Controls -->
        <div class="flex items-center gap-2 ml-auto">
          <ThemeToggle client:load />
          <LanguageSwitcher client:load currentLang={lang} />
          {session && (
            <UserDropdown client:load username={username ?? ""} name={userName ?? ""} avatarUrl={userAvatarUrl} lang={lang} role={userRole} />
          )}
        </div>
      </div>
    </header>

    <!-- Body: sidebar + content -->
    <div class="flex" style="min-height:calc(100vh - 48px)">

      <!-- Sidebar -->
      <aside class="w-48 shrink-0 border-r" style="background:var(--color-bg-panel); border-color:var(--color-border-subtle)">
        <nav class="px-2 py-5 space-y-0.5">
          {navLinks.map((link) => {
            const isActive = currentPath === link.href;
            return (
              <a
                href={link.href}
                class="flex items-center px-3 py-2 rounded text-sm transition-colors"
                style={`font-weight:510; font-feature-settings:'cv01','ss03'; color:${isActive ? "var(--color-text-primary)" : "var(--color-text-subtle)"}; background:${isActive ? "var(--color-bg-card-elev)" : "transparent"}`}
              >
                {link.label}
              </a>
            );
          })}
        </nav>
      </aside>

      <!-- Main content -->
      <main class="flex-1 min-w-0">
        <div class="max-w-5xl mx-auto px-8 py-8">
          <slot />
        </div>
      </main>

    </div>

  </body>
</html>
